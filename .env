TZ=Europe/Warsaw

# Portainer stack variables. Replace defaults before deploying.
POSTGRES_DB=deu_sec_lab
POSTGRES_USER=deu_sec_lab
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://deu_sec_lab:change_me@postgres:5432/deu_sec_lab

REDIS_URL=redis://redis:6379/0
REPORTS_ROOT=/reports
INTERNAL_API_URL=http://api:8000

ALLOW_PRIVATE_TARGETS=false
NMAP_ALLOWED_PORTS=80,443,8080,8443

SECRET_KEY=change_me

# Optional. Reports are generated without AI when this is empty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
